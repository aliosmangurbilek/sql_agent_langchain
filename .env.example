# Example environment variables for sql_agent_langchain
# Copy to .env and adjust.

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
TRUST_PROXY_HEADERS=0

# OpenRouter (Required) - get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Default model (can be overridden per request via frontend model select if implemented)
OPENROUTER_MODEL=deepseek/deepseek-chat

# Optional: LangChain tracing (if you have LangSmith / tracing enabled)
LANGCHAIN_TRACING_V2=0
LANGCHAIN_API_KEY=

# Default database (UI can override). Examples:
# PostgreSQL: postgresql://user:pass@localhost:5432/mydb
# SQLite file: sqlite:///my.db
# Docker Compose overrides this automatically for the bundled Postgres service.
DEFAULT_DB_URI=sqlite:///langchain_agent.db
# SQLAlchemy pool tuning for PostgreSQL
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# Set to 1 to disable pooling and open/close DB connection per request
DB_USE_NULLPOOL=0
# Bounded in-process QueryEngine cache size (per worker process)
QUERY_ENGINE_CACHE_SIZE=2
# Optional fixed dropdown order. Leave blank to auto-discover databases from the server.
DATABASE_OPTIONS=

# Vector store path (used if/when a local persistence path is required)
VECTOR_STORE_PATH=storage/vectors

# Embedding runtime
EMBEDDING_MODEL=intfloat/e5-large-v2
EMBEDDING_DEVICE=cpu

# Schema change detection mode:
#   off  - ignore changes
#   mark - (default) mark needs_rebuild flag, do not auto rebuild
#   auto - (future) auto rebuild embeddings on change
SCHEMA_CHANGE_MODE=mark

# Chart size defaults
CHART_WIDTH=800
CHART_HEIGHT=400

# Docker Compose deployment
POSTGRES_DB=postgres
POSTGRES_USER=sqlagent
POSTGRES_PASSWORD=change-this
DEFAULT_SAMPLE_DB=pagila
SAMPLE_DATABASES=pagila,chinook,titanic,netflix,periodic_table,happiness_index
APP_PORT=5000
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=240

# (Advanced) Set to INFO/DEBUG to control log verbosity
# LOG_LEVEL=INFO
