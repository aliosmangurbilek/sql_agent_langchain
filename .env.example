# Example environment variables for sql_agent_langchain
# Copy to .env and adjust.

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# OpenRouter (Required) - get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Default model (can be overridden per request via frontend model select if implemented)
OPENROUTER_MODEL=deepseek/deepseek-chat

# Optional: LangChain tracing (if you have LangSmith / tracing enabled)
LANGCHAIN_TRACING_V2=0
LANGCHAIN_API_KEY=

# Default database (UI can override). Examples:
# PostgreSQL: postgresql://user:pass@localhost:5432/mydb
# SQLite file: sqlite:///my.db
DEFAULT_DB_URI=sqlite:///langchain_agent.db

# Vector store path (used if/when a local persistence path is required)
VECTOR_STORE_PATH=storage/vectors

# Schema change detection mode:
#   off  - ignore changes
#   mark - (default) mark needs_rebuild flag, do not auto rebuild
#   auto - (future) auto rebuild embeddings on change
SCHEMA_CHANGE_MODE=mark

# Chart size defaults
CHART_WIDTH=800
CHART_HEIGHT=400

# (Advanced) Set to INFO/DEBUG to control log verbosity
# LOG_LEVEL=INFO

